{
  "name": "restlab-nodejs",
  "version": "1.0.0",
  "description": "Restlab backend server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "package:deb": "bash packaging/deb/build-deb.sh",
    "package:tar": "bash packaging/tar/build-tarball.sh",
    "package": "npm run package:deb && npm run package:tar"
  },
  "author": "example.com",
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.1",
    "node-hid": "^3.1.2",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.10",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
