[Unit]
Description=Restlab backend
After=network.target

[Service]
Type=simple
User=restlab
WorkingDirectory=/opt/restlab
ExecStart=/opt/restlab/myapp
Restart=on-failure
RestartSec=3
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=RESTLAB_DATA_DIR=/opt/restlab/restlab-data

[Install]
WantedBy=multi-user.target
